@page
@using SSEChannel.Core.Pages
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<style>
    .messages {
        border: 1px solid #ccc;
        height: 300px;
        overflow-y: auto;
        padding: 10px;
        margin: 10px 0;
    }

    .message {
        margin: 5px 0;
        padding: 5px;
        background: #f5f5f5;
        border-radius: 3px;
    }

    input, button {
        padding: 8px;
        margin: 5px;
    }

        input[type="text"] {
            width: 300px;
        }

    .status {
        color: #666;
        font-style: italic;
    }
</style>

<div class="container text-center">
    <h1>Server Sent Events with Channels - Sample Demo</h1>
    <ul style="text-align: left !important;">
        <li><strong>Connection Partitioning</strong>: Distributes connections across multiple partitions</li>
        <li><strong>Parallel Processing</strong>: Concurrent message delivery for maximum throughput</li>
        <li><strong>Real-time Statistics</strong>: Live connection and performance metrics</li>
        <li><strong>Auto-cleanup</strong>: Automatic management of disconnected clients</li>
    </ul>

    <div>
        <button onclick="connect()">Connect to SSE</button>
        <button onclick="disconnect()">Disconnect</button>
        <span id="status" class="status">Disconnected</span>
    </div>

    <div>
        <input type="text" id="messageInput" placeholder="Enter message (min 10 chars)" />
        <button onclick="sendMessage()">Send Message</button>
    </div>

    <div>
        <button onclick="getClients()">Get Connection Stats</button>
        <button onclick="sendBroadcast()">Send Broadcast</button>
    </div>

    <div>
        <input type="text" id="broadcastMessage" placeholder="Broadcast message" value="Hello everyone!" />
    </div>

    <div id="messages" class="messages"></div>
</div>

<script type="text/javascript">
    let eventSource = null;
    let clientId = null;

    function connect() {
        if (eventSource) {
            eventSource.close();
        }

        clientId = generateGuid();
        addMessage(`Attempting to connect with client ID: ${clientId}`, 'status');

        // Use scalable notification service endpoint
        eventSource = new EventSource(`/api/notifications/stream/${clientId}`);

        eventSource.addEventListener('connected', function(event) {
            clientId = event.data;
            document.getElementById('status').textContent = `Connected (Client: ${clientId})`;
            addMessage(`Connected successfully as ${clientId}`, 'status');
        });

        eventSource.addEventListener('message', function(event) {
            addMessage(event.data, 'message');
        });

        eventSource.addEventListener('error', function(event) {
            document.getElementById('status').textContent = 'Connection error';
            addMessage('Connection error occurred - will retry automatically', 'status');
            console.error('SSE Error:', event);
        });

        eventSource.onerror = function(error) {
            document.getElementById('status').textContent = 'Connection error';
            addMessage('Connection error occurred - will retry automatically', 'status');
            console.error('SSE Error:', error);
        };
    }

    function disconnect() {
        if (eventSource) {
            eventSource.close();
            eventSource = null;
            document.getElementById('status').textContent = 'Disconnected';
            addMessage('Disconnected from SSE stream', 'status');
        }
    }

    async function sendMessage() {
        const input = document.getElementById('messageInput');
        const message = input.value.trim();

        if (message.length < 10) {
            alert('Message must be at least 10 characters long');
            return;
        }

        if (!clientId) {
            alert('Not connected. Please connect first.');
            return;
        }

        try {
            // Use scalable notification service endpoint
            const response = await fetch(`/api/notifications/send/${clientId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    message: message
                })
            });

            if (response.ok) {
                addMessage(`Sent: ${message}`, 'status');
                input.value = '';
            } else {
                addMessage(`Failed to send message: ${response.statusText}`, 'status');
            }
        } catch (error) {
            addMessage(`Error sending message: ${error.message}`, 'status');
        }
    }

    async function getClients() {
        try {
            // Use scalable notification service stats endpoint
            const response = await fetch('/api/notifications/stats');
            const data = await response.json();
            addMessage(`Connection Stats - Total: ${data.totalConnections}, Active: ${data.activeConnections}, Messages/sec: ${data.messagesPerSecond}`, 'status');
        } catch (error) {
            addMessage(`Error getting stats: ${error.message}`, 'status');
        }
    }

    function addMessage(text, type) {
        const messages = document.getElementById('messages');
        const div = document.createElement('div');
        div.className = type;
        div.textContent = `[${new Date().toLocaleTimeString()}] ${text}`;
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }



    async function sendBroadcast() {
        const message = document.getElementById('broadcastMessage').value.trim();
        if (!message) {
            addMessage('Please enter a broadcast message', 'status');
            return;
        }

        try {
            const response = await fetch('/api/notifications/broadcast/all', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: message })
            });

            if (response.ok) {
                addMessage(`Broadcast sent: ${message}`, 'status');
            } else {
                addMessage('Failed to send broadcast', 'status');
            }
        } catch (error) {
            addMessage(`Error sending broadcast: ${error.message}`, 'status');
        }
    }



    function generateGuid() {
        return crypto.randomUUID();
    }

    // Auto-connect on page load
    window.onload = function() {
        connect();
    };
</script>
