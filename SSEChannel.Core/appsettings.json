{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SSEChannelDemo": "Information"
    }
  },
  "AllowedHosts": "*",
  "SseChannel": {
    "HeartbeatInterval": "00:00:20",
    "ReplayBufferSize": 100,
    "MaxChannelNameLength": 64,
    "UseRedisBackplane": false,
    "RedisConnectionString": null
  },
  "Notifications": {
    "PartitionCount": 16,
    "BroadcastIntervalMs": 2000,
    "StatsIntervalMs": 10000,
    "MaxConnectionsPerPartition": 100000,
    "CleanupIntervalMs": 30000
  },
  "Kestrel": {
    "Limits": {
      "MaxConcurrentConnections": 1000000,
      "MaxConcurrentUpgradedConnections": 1000000,
      "MaxRequestBodySize": 1048576,
      "KeepAliveTimeout": "00:02:00",
      "RequestHeadersTimeout": "00:00:30"
    }
  }
}