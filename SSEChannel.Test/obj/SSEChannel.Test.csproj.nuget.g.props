<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">/home/runner/.nuget/packages/</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">/home/runner/.nuget/packages/</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="/home/runner/.nuget/packages/" />
  </ItemGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)microsoft.extensions.telemetry.abstractions/9.7.0/buildTransitive/net8.0/Microsoft.Extensions.Telemetry.Abstractions.props" Condition="Exists('$(NuGetPackageRoot)microsoft.extensions.telemetry.abstractions/9.7.0/buildTransitive/net8.0/Microsoft.Extensions.Telemetry.Abstractions.props')" />
    <Import Project="$(NuGetPackageRoot)mstest.analyzers/3.9.0/buildTransitive/MSTest.Analyzers.props" Condition="Exists('$(NuGetPackageRoot)mstest.analyzers/3.9.0/buildTransitive/MSTest.Analyzers.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.platform/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Platform.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.platform/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Platform.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.platform.msbuild/1.7.0/buildTransitive/Microsoft.Testing.Platform.MSBuild.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.platform.msbuild/1.7.0/buildTransitive/Microsoft.Testing.Platform.MSBuild.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.telemetry/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.Telemetry.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.telemetry/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.Telemetry.props')" />
    <Import Project="$(NuGetPackageRoot)mstest.testadapter/3.9.0/buildTransitive/net9.0/MSTest.TestAdapter.props" Condition="Exists('$(NuGetPackageRoot)mstest.testadapter/3.9.0/buildTransitive/net9.0/MSTest.TestAdapter.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testplatform.testhost/17.13.0/build/netcoreapp3.1/Microsoft.TestPlatform.TestHost.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testplatform.testhost/17.13.0/build/netcoreapp3.1/Microsoft.TestPlatform.TestHost.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.trxreport/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.TrxReport.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.trxreport/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.TrxReport.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.retry/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.Retry.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.retry/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.Retry.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.hotreload/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.HotReload.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.hotreload/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.HotReload.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.hangdump/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.HangDump.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.hangdump/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.HangDump.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.fakes/17.14.1/buildTransitive/netstandard2.0/Microsoft.Testing.Extensions.Fakes.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.fakes/17.14.1/buildTransitive/netstandard2.0/Microsoft.Testing.Extensions.Fakes.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.crashdump/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.CrashDump.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.crashdump/1.7.0/buildTransitive/net9.0/Microsoft.Testing.Extensions.CrashDump.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.testing.extensions.codecoverage/17.14.2/buildTransitive/net8.0/Microsoft.Testing.Extensions.CodeCoverage.props" Condition="Exists('$(NuGetPackageRoot)microsoft.testing.extensions.codecoverage/17.14.2/buildTransitive/net8.0/Microsoft.Testing.Extensions.CodeCoverage.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.codecoverage/17.13.0/build/netstandard2.0/Microsoft.CodeCoverage.props" Condition="Exists('$(NuGetPackageRoot)microsoft.codecoverage/17.13.0/build/netstandard2.0/Microsoft.CodeCoverage.props')" />
    <Import Project="$(NuGetPackageRoot)microsoft.net.test.sdk/17.13.0/build/netcoreapp3.1/Microsoft.NET.Test.Sdk.props" Condition="Exists('$(NuGetPackageRoot)microsoft.net.test.sdk/17.13.0/build/netcoreapp3.1/Microsoft.NET.Test.Sdk.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgMSTest_Analyzers Condition=" '$(PkgMSTest_Analyzers)' == '' ">/home/runner/.nuget/packages/mstest.analyzers/3.9.0</PkgMSTest_Analyzers>
  </PropertyGroup>
</Project>